<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Confirmation - Heure Haute</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Cormorant+Garamond:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
      color: #fff;
      font-family: 'Cormorant Garamond', serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      overflow-x: hidden;
    }

    .container {
      max-width: 900px;
      width: 100%;
    }

    header {
      text-align: center;
      margin-bottom: 60px;
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      letter-spacing: 3px;
      margin-bottom: 10px;
      font-weight: 400;
    }

    .confirmation-section {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(212, 175, 55, 0.3);
      border-radius: 12px;
      padding: 60px 40px;
      backdrop-filter: blur(10px);
      text-align: center;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    .success-icon {
      font-size: 4rem;
      margin-bottom: 30px;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.05); opacity: 0.8; }
    }

    .confirmation-section h1 {
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem;
      letter-spacing: 2px;
      margin-bottom: 15px;
      font-weight: 400;
      color: #d4af37;
    }

    .confirmation-message {
      font-size: 1.3rem;
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 50px;
      font-weight: 300;
    }

    .order-details {
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 8px;
      padding: 40px;
      margin-bottom: 50px;
      text-align: left;
    }

    .detail-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 0;
      border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    }

    .detail-row:last-child {
      border-bottom: none;
    }

    .detail-label {
      color: rgba(255, 255, 255, 0.6);
      font-size: 1.1rem;
      font-weight: 400;
    }

    .detail-value {
      color: #d4af37;
      font-size: 1.2rem;
      font-weight: 600;
      font-family: 'Courier New', monospace;
    }

    .timeline {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 50px 0;
      gap: 20px;
    }

    .timeline-step {
      flex: 1;
      text-align: center;
      position: relative;
    }

    .timeline-step::after {
      content: '';
      position: absolute;
      top: 40px;
      left: 50%;
      width: 100%;
      height: 2px;
      background: rgba(212, 175, 55, 0.2);
      z-index: -1;
    }

    .timeline-step:last-child::after {
      display: none;
    }

    .step-icon {
      width: 80px;
      height: 80px;
      background: rgba(212, 175, 55, 0.1);
      border: 2px solid rgba(212, 175, 55, 0.4);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 15px;
      font-size: 2rem;
    }

    .timeline-step.completed .step-icon {
      background: rgba(212, 175, 55, 0.2);
      border-color: #d4af37;
    }

    .step-label {
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.7);
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-top: 50px;
    }

    .btn {
      padding: 18px 40px;
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      letter-spacing: 1px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-block;
      text-align: center;
      font-weight: 500;
    }

    .continue-btn {
      background: rgba(212, 175, 55, 0.1);
      color: #d4af37;
      border: 2px solid #d4af37;
    }

    .continue-btn:hover {
      background: #d4af37;
      color: #000;
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
    }

    .track-btn {
      background: #d4af37;
      color: #000;
      border: 2px solid #d4af37;
      font-weight: 700;
    }

    .track-btn:hover {
      background: rgba(212, 175, 55, 0.9);
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(212, 175, 55, 0.4);
    }

    .estimated-delivery {
      background: rgba(212, 175, 55, 0.05);
      border-left: 4px solid #d4af37;
      padding: 20px;
      margin: 30px 0;
      border-radius: 4px;
      font-size: 1rem;
    }

    @media (max-width: 768px) {
      .confirmation-section {
        padding: 40px 20px;
      }

      .confirmation-section h1 {
        font-size: 2.5rem;
      }

      .actions {
        grid-template-columns: 1fr;
      }

      .timeline {
        flex-direction: column;
      }

      .timeline-step::after {
        display: none;
      }

      .order-details {
        padding: 20px;
      }

      .detail-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div class="logo">⌘ HEURE HAUTE</div>
      <p style="font-size: 0.95rem; color: rgba(255, 255, 255, 0.5); margin-top: 10px;">Luxury Timepieces</p>
    </header>

    <section class="confirmation-section">
      <div class="success-icon">✓</div>
      
      <h1>Order Confirmed</h1>
      <p class="confirmation-message">Thank you for your purchase of exceptional timepieces</p>

      <div class="order-details">
        <div class="detail-row">
          <span class="detail-label">Order ID</span>
          <span class="detail-value" id="orderId">---</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Status</span>
          <span class="detail-value">Processing</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Email Confirmation</span>
          <span class="detail-value" id="userEmail">---</span>
        </div>
      </div>

      <div class="estimated-delivery">
        📦 Estimated Delivery: <strong>5-7 Business Days</strong><br>
        <small>Track your package for real-time updates</small>
      </div>

      <div class="timeline">
        <div class="timeline-step completed">
          <div class="step-icon">✓</div>
          <div class="step-label">Order Placed</div>
        </div>
        <div class="timeline-step">
          <div class="step-icon">📦</div>
          <div class="step-label">Processing</div>
        </div>
        <div class="timeline-step">
          <div class="step-icon">🚚</div>
          <div class="step-label">Shipped</div>
        </div>
        <div class="timeline-step">
          <div class="step-icon">🎁</div>
          <div class="step-label">Delivered</div>
        </div>
      </div>

      <div class="actions">
        <a href="/catalogue" class="btn continue-btn">Continue Shopping</a>
        <a href="/track-package" class="btn track-btn">Track Package</a>
      </div>
    </section>
  </div>

  <script>
    // Display order ID and email from localStorage
    document.addEventListener('DOMContentLoaded', function() {
      const orderId = localStorage.getItem('lastOrderId');
      const userEmail = localStorage.getItem('userId');
      
      if (orderId) {
        document.getElementById('orderId').textContent = orderId;
      }
      
      if (userEmail) {
        document.getElementById('userEmail').textContent = userEmail;
      }
    });
  </script>
</body>
</html>
